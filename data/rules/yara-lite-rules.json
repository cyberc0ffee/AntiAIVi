{
  "version": "0.1.0",
  "rules": [
    {
      "id": "powershell_downloader",
      "name": "PowerShell Downloader Pattern",
      "category": "Loader",
      "severity": "high",
      "score": 55,
      "match": "all",
      "patterns": [
        { "text": "DownloadString", "nocase": true },
        { "text": "IEX", "nocase": true }
      ]
    },
    {
      "id": "encoded_powershell",
      "name": "Encoded PowerShell Command",
      "category": "LOLBIN",
      "severity": "high",
      "score": 45,
      "match": "any",
      "patterns": [
        { "regex": "-e(nc|ncodedcommand)?\\s+[A-Za-z0-9+/=]{20,}", "nocase": true },
        { "text": "FromBase64String", "nocase": true }
      ]
    },
    {
      "id": "js_activex_downloader",
      "name": "JScript ActiveX Downloader",
      "category": "Trojan",
      "severity": "high",
      "score": 50,
      "match": "all",
      "patterns": [
        { "text": "ActiveXObject", "nocase": true },
        { "text": "MSXML2.XMLHTTP", "nocase": true }
      ]
    },
    {
      "id": "batch_certutil_download",
      "name": "Certutil Download",
      "category": "LOLBIN",
      "severity": "medium",
      "score": 35,
      "match": "all",
      "patterns": [
        { "text": "certutil", "nocase": true },
        { "text": "-urlcache", "nocase": true }
      ]
    },
    {
      "id": "packer_markers",
      "name": "Common Packer Markers",
      "category": "Packed",
      "severity": "medium",
      "score": 30,
      "match": "any",
      "patterns": [
        { "text": "UPX0", "nocase": false },
        { "text": "UPX1", "nocase": false },
        { "text": "Themida", "nocase": true },
        { "text": "VMProtect", "nocase": true },
        { "text": "ASPack", "nocase": true }
      ]
    }
  ]
}
